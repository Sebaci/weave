{
  "name": "weave-language",
  "displayName": "Weave",
  "description": "Language support for the Weave language",
  "version": "0.1.0",
  "publisher": "weave-lang",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:weave"],
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "languages": [
      {
        "id": "weave",
        "aliases": ["Weave", "weave"],
        "extensions": [".weave"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "weave",
        "scopeName": "source.weave",
        "path": "./syntaxes/weave.tmLanguage.json"
      }
    ]
  }
}
