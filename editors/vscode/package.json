{
  "name": "weave-language",
  "displayName": "Weave",
  "description": "Language support for the Weave language",
  "version": "0.1.0",
  "publisher": "weave-lang",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:weave"],
  "scripts": {
    "compile:ext": "tsc -p tsconfig.json",
    "compile:server": "esbuild ../../src/lsp/server.ts --bundle --platform=node --format=esm --outfile=out/server.mjs",
    "compile": "npm run compile:ext && npm run compile:server",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "contributes": {
    "languages": [
      {
        "id": "weave",
        "aliases": ["Weave", "weave"],
        "extensions": [".weave"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "weave",
        "scopeName": "source.weave",
        "path": "./syntaxes/weave.tmLanguage.json"
      }
    ]
  }
}
