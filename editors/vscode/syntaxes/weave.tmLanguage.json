{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Weave",
  "scopeName": "source.weave",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#def-name" },
    { "include": "#keyword" },
    { "include": "#boolean" },
    { "include": "#number" },
    { "include": "#type-name" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "match": "--.*$",
      "name": "comment.line.double-dash.weave"
    },
    "string": {
      "name": "string.quoted.double.weave",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.weave"
        }
      ]
    },
    "keyword": {
      "name": "keyword.other.weave",
      "match": "\\b(module|import|type|def|effect|case|fold|build|fanout|over|let|in|perform|pure|parallel-safe|sequential)\\b"
    },
    "boolean": {
      "match": "\\b(True|False)\\b",
      "name": "constant.language.boolean.weave"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\.[0-9]+\\b",
          "name": "constant.numeric.float.weave"
        },
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.integer.weave"
        }
      ]
    },
    "def-name": {
      "match": "\\b(def)\\s+([a-z_][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.other.weave" },
        "2": { "name": "entity.name.function.weave" }
      }
    },
    "type-name": {
      "match": "\\b[A-Z][a-zA-Z0-9_']*\\b",
      "name": "entity.name.type.weave"
    },
    "operator": {
      "match": ">>>|->|==|!=|<=|>=|&&|\\|\\||[|.=:<>+\\-*/!]",
      "name": "keyword.operator.weave"
    }
  }
}
