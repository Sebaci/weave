{
  "name": "weave",
  "version": "0.10.5",
  "type": "module",
  "bin": {
    "weave": "dist/weave.js"
  },
  "scripts": {
    "prepare": "npm run build:cli",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts",
    "build:cli": "node scripts/build-cli.mjs",
    "lsp": "tsx src/lsp/server.ts",
    "bundle:lsp": "esbuild src/lsp/server.ts --bundle --platform=node --format=cjs --define:import.meta.url='\"file:///server.js\"' --outfile=editors/vscode/out/server.js",
    "build:ext": "npm --prefix editors/vscode install && npm --prefix editors/vscode run compile",
    "package:ext": "npm --prefix editors/vscode run package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
