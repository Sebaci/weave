{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "vscode-languageserver/node": ["./node_modules/vscode-languageserver/node.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
